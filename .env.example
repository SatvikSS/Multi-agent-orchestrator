# Provider API keys — set only the ones you use. All optional; validated at startup per active role.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama (local). Default assumes a local daemon.
OLLAMA_BASE_URL=http://localhost:11434

# GitHub personal access token — needed only for GitHub issue fetch / PR creation.
GITHUB_TOKEN=

# LangSmith observability (optional). Enable to trace graph runs.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=repo-surgeon
